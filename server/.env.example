# ─────────────────────────────────────────────────
# ROUTELYTICS — Server Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────

# Server port (Render sets this automatically)
PORT=5000

# MongoDB Atlas connection string
# Get this from: MongoDB Atlas → Cluster → Connect → Application
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=<AppName>

# JWT Secret — use a long random string in production
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret

# AI Service URL
# Local: http://localhost:8000
# Production: https://routelytics-ai.onrender.com (set AFTER AI service is deployed)
AI_SERVICE_URL=http://localhost:8000

# Frontend URL for CORS (your Vercel deployment URL)
# Example: https://routelytics.vercel.app
FRONTEND_URL=http://localhost:5173
