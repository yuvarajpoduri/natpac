# ────────────────────────────────────────
# Routelytics — Root .gitignore
# ────────────────────────────────────────

# Node / Server
server/node_modules/
server/.env

# Client
client/node_modules/
client/dist/
client/.env
client/.env.local

# Python / AI Service
ai_service/__pycache__/
ai_service/*.pyc
ai_service/venv/
ai_service/.venv/
ai_service/*.egg-info/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Render
.render/
